{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "*{.html,.css,.js}"
    },
    "src/server.js": {
      "includeFiles": "*{.html,.css,.js}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
