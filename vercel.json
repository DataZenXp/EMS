{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "{src/**,public/**,.env*,package.json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
